# Copy to deploy/env/.env.server on the OCI server and fill in real secrets.

APP_ENV=server
APP_TIMEZONE=Asia/Seoul
APP_LOG_LEVEL=INFO
APP_DATA_DIR=/workspace/data
APP_DUCKDB_PATH=/workspace/data/marts/main.duckdb
APP_ARTIFACTS_DIR=/workspace/artifacts

# Host layout
DOCKER_COMPOSE_PROJECT_NAME=stockmaster
STOCKMASTER_PROJECT_ROOT=/opt/stockmaster/app
STOCKMASTER_RUNTIME_ROOT=/opt/stockmaster/runtime
STOCKMASTER_BACKUP_ROOT=/opt/stockmaster/backups
STOCKMASTER_SERVER_IMAGE=stockmaster-server:latest

# Providers
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_PRODUCT_CODE=
KIS_USE_MOCK=false

DART_API_KEY=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

KRX_API_KEY=
ENABLE_KRX_LIVE=false
KRX_ALLOWED_SERVICES=
KRX_DAILY_REQUEST_BUDGET=1000
KRX_REQUEST_TIMEOUT_SECONDS=20
KRX_SOURCE_ATTRIBUTION_LABEL=한국거래소 통계정보

# Discord is conservative by default on server.
DISCORD_REPORT_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=KR Stock Research Bot
DISCORD_BOT_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_BOT_APPLICATION_ID=
DISCORD_BOT_GUILD_ID=

# Server default: keep operational metadata in Postgres, not in DuckDB.
METADATA_DB_ENABLED=true
METADATA_DB_BACKEND=postgres
METADATA_DB_URL=
METADATA_DB_SCHEMA=public
METADATA_DB_POSTGRES_DB=stockmaster_meta
METADATA_DB_POSTGRES_USER=stockmaster
METADATA_DB_POSTGRES_PASSWORD=change_me
METADATA_DB_HOST_PORT=5433

# Storage and retention
STORAGE_WARNING_RATIO=0.70
STORAGE_PRUNE_RATIO=0.80
STORAGE_LIMIT_RATIO=0.90

RETENTION_RAW_API_DAYS=14
RETENTION_INTRADAY_5M_DAYS=45
RETENTION_INTRADAY_1M_DAYS=30
RETENTION_ORDERBOOK_SUMMARY_DAYS=21
RETENTION_REPORT_CACHE_DAYS=21
RETENTION_LOG_DAYS=30

# Model defaults
MODEL_DEFAULT_HORIZONS=D1,D5
MODEL_UNCERTAINTY_LAMBDA=1.0
MODEL_DISAGREEMENT_ETA=1.0
MODEL_IMPLEMENTATION_KAPPA=1.0
MODEL_REGIME_RHO=1.0

# Intraday research mode
ENABLE_INTRADAY_RESEARCH=true
ENABLE_INTRADAY_ASSIST=true
ENABLE_INTRADAY_POSTMORTEM=true
ENABLE_INTRADAY_POLICY_ADJUSTMENT=true
ENABLE_INTRADAY_META_MODEL=true
ENABLE_INTRADAY_POLICY_AUTO_ACTIVATION=true
ENABLE_INTRADAY_META_MODEL_AUTO_ACTIVATION=true
ENABLE_INTRADAY_RESEARCH_REPORTS=true
ENABLE_INTRADAY_DISCORD_SUMMARY=false
ENABLE_INTRADAY_WRITEBACK=true
