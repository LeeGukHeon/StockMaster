# Copy to deploy/env/.env.server on the OCI server and fill in real secrets.

APP_ENV=server
APP_TIMEZONE=Asia/Seoul
APP_LOG_LEVEL=INFO
APP_DATA_DIR=/workspace/data
APP_DUCKDB_PATH=/workspace/data/marts/main.duckdb

# Streamlit runtime
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
PUBLIC_PORT=80
APP_BASE_URL=http://YOUR_PUBLIC_IP
REVERSE_PROXY_ENABLED=true
BASE_URL_PATH=

# Host layout
DOCKER_COMPOSE_PROJECT_NAME=stockmaster
STOCKMASTER_PROJECT_ROOT=/opt/stockmaster/app
STOCKMASTER_RUNTIME_ROOT=/opt/stockmaster/runtime
STOCKMASTER_BACKUP_ROOT=/opt/stockmaster/backups
STOCKMASTER_SERVER_IMAGE=stockmaster-server:latest

# Providers
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_PRODUCT_CODE=
KIS_USE_MOCK=false

DART_API_KEY=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

KRX_API_KEY=

# Discord is conservative by default on server.
DISCORD_REPORT_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=KR Stock Research Bot

# Storage and retention
STORAGE_WARNING_RATIO=0.70
STORAGE_PRUNE_RATIO=0.80
STORAGE_LIMIT_RATIO=0.90

RETENTION_RAW_API_DAYS=14
RETENTION_INTRADAY_5M_DAYS=45
RETENTION_INTRADAY_1M_DAYS=30
RETENTION_ORDERBOOK_SUMMARY_DAYS=21
RETENTION_REPORT_CACHE_DAYS=21
RETENTION_LOG_DAYS=30

# Model defaults
MODEL_DEFAULT_HORIZONS=D1,D5
MODEL_UNCERTAINTY_LAMBDA=1.0
MODEL_DISAGREEMENT_ETA=1.0
MODEL_IMPLEMENTATION_KAPPA=1.0
MODEL_REGIME_RHO=1.0
